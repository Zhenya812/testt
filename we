<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Список справ</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
    }

    :root {
      --page-bg: #f2f4f8;
      --app-bg: #ffffff;
      --panel-bg: #f5f7fb;
      --soft-bg: #e8ecf3;
      --text-main: #222;
      --text-muted: #444;
      --text-light: #667085;
      --border-color: #dfe5f0;
      --input-border: #cfd6e4;
      --primary: #2d6cdf;
      --primary-hover: #1f55b5;
      --shadow-main: rgba(0, 0, 0, 0.1);
      --modal-shadow: rgba(0, 0, 0, 0.25);
    }

    body {
      min-height: 100vh;
      background: var(--page-bg);
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 40px 15px;
      color: var(--text-main);
      transition: background 0.3s ease, color 0.3s ease;
    }

    body.theme-dark {
      --page-bg: #111827;
      --app-bg: #1f2937;
      --panel-bg: #273449;
      --soft-bg: #374151;
      --text-main: #f9fafb;
      --text-muted: #d1d5db;
      --text-light: #9ca3af;
      --border-color: #4b5563;
      --input-border: #6b7280;
      --primary: #60a5fa;
      --primary-hover: #3b82f6;
      --shadow-main: rgba(0, 0, 0, 0.35);
      --modal-shadow: rgba(0, 0, 0, 0.55);
    }

    body.theme-gradient-berries {
      --page-bg: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
      --app-bg: rgba(255, 255, 255, 0.92);
      --panel-bg: rgba(245, 247, 251, 0.9);
      --soft-bg: rgba(232, 236, 243, 0.9);
      --text-main: #1f2937;
      --text-muted: #374151;
      --text-light: #667085;
      --border-color: rgba(223, 229, 240, 0.9);
      --input-border: #cfd6e4;
      --primary: #7c3aed;
      --primary-hover: #5b21b6;
      --shadow-main: rgba(31, 41, 55, 0.22);
      --modal-shadow: rgba(31, 41, 55, 0.35);
    }

    body.theme-gradient-sunset {
      --page-bg: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 45%, #fad0c4 100%);
      --app-bg: rgba(255, 255, 255, 0.93);
      --panel-bg: rgba(255, 245, 242, 0.92);
      --soft-bg: rgba(255, 230, 224, 0.9);
      --text-main: #2d1b1b;
      --text-muted: #4b2c2c;
      --text-light: #795454;
      --border-color: rgba(255, 197, 188, 0.95);
      --input-border: #e7b7b0;
      --primary: #e11d48;
      --primary-hover: #be123c;
      --shadow-main: rgba(80, 20, 30, 0.2);
      --modal-shadow: rgba(80, 20, 30, 0.35);
    }

    body.theme-gradient-ocean {
      --page-bg: linear-gradient(135deg, #00c6ff 0%, #0072ff 50%, #6a11cb 100%);
      --app-bg: rgba(255, 255, 255, 0.92);
      --panel-bg: rgba(235, 247, 255, 0.9);
      --soft-bg: rgba(219, 239, 255, 0.9);
      --text-main: #102033;
      --text-muted: #243b55;
      --text-light: #55708f;
      --border-color: rgba(186, 219, 245, 0.95);
      --input-border: #9fc3e0;
      --primary: #0284c7;
      --primary-hover: #0369a1;
      --shadow-main: rgba(12, 52, 95, 0.22);
      --modal-shadow: rgba(12, 52, 95, 0.35);
    }

    body.theme-gradient-forest {
      --page-bg: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
      --app-bg: rgba(255, 255, 255, 0.92);
      --panel-bg: rgba(238, 255, 245, 0.9);
      --soft-bg: rgba(220, 252, 231, 0.9);
      --text-main: #123026;
      --text-muted: #214438;
      --text-light: #527565;
      --border-color: rgba(172, 230, 197, 0.95);
      --input-border: #92cfae;
      --primary: #059669;
      --primary-hover: #047857;
      --shadow-main: rgba(18, 48, 38, 0.22);
      --modal-shadow: rgba(18, 48, 38, 0.35);
    }

    .app {
      width: 100%;
      max-width: 850px;
      background: var(--app-bg);
      border-radius: 16px;
      padding: 25px;
      box-shadow: 0 10px 30px var(--shadow-main);
    }

    h1 {
      text-align: center;
      margin-bottom: 20px;
      color: var(--text-main);
    }

    .theme-panel {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
      color: var(--text-muted);
      font-size: 14px;
    }

    .theme-panel select {
      border: 1px solid var(--input-border);
      border-radius: 8px;
      padding: 9px 10px;
      font-size: 14px;
      outline: none;
      background: var(--app-bg);
      color: var(--text-main);
      cursor: pointer;
    }

    .theme-panel select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(45, 108, 223, 0.15);
    }

    .top-panel {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      background: var(--panel-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 14px;
    }

    .top-panel-text {
      color: var(--text-muted);
      font-size: 14px;
    }

    .open-modal-btn,
    .modal-actions button,
    .task button,
    .tabs button,
    .clear-history {
      border: none;
      border-radius: 8px;
      padding: 10px 14px;
      cursor: pointer;
      font-size: 14px;
      transition: 0.2s;
    }

    .open-modal-btn,
    .save-task-btn {
      background: var(--primary);
      color: white;
    }

    .open-modal-btn:hover,
    .save-task-btn:hover {
      background: var(--primary-hover);
    }

    .cancel-modal-btn {
      background: #6c757d;
      color: white;
    }

    .tabs {
      display: flex;
      gap: 10px;
      margin-bottom: 14px;
    }

    .tabs button {
      flex: 1;
      background: var(--soft-bg);
      color: var(--text-main);
    }

    .tabs button.active {
      background: var(--primary);
      color: #fff;
    }

    .category-tabs {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }

    .category-tabs button {
      border: none;
      border-radius: 8px;
      padding: 9px 12px;
      cursor: pointer;
      font-size: 14px;
      background: var(--soft-bg);
      color: var(--text-main);
      transition: 0.2s;
    }

    .category-tabs button.active {
      background: var(--primary);
      color: #fff;
    }

    .task-category {
      display: inline-block;
      margin-top: 4px;
      padding: 3px 7px;
      border-radius: 999px;
      background: rgba(45, 108, 223, 0.12);
      color: #1f55b5;
      font-size: 12px;
      font-weight: bold;
    }

    .stats {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 20px;
      color: var(--text-muted);
      font-size: 14px;
    }

    .stat-box {
      flex: 1;
      background: var(--panel-bg);
      padding: 12px;
      border-radius: 10px;
      text-align: center;
    }

    .legend {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 12px;
      font-size: 13px;
    }

    .filter-panel {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 20px;
    }

    .filter-open-btn {
      border: none;
      border-radius: 8px;
      padding: 10px 16px;
      cursor: pointer;
      font-size: 14px;
      background: var(--primary);
      color: #fff;
      transition: 0.2s;
    }

    .filter-open-btn:hover {
      background: var(--primary-hover);
    }

    .filters {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      margin-bottom: 10px;
    }

    .filter-field {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .filter-field label {
      font-size: 12px;
      font-weight: bold;
      color: var(--text-main);
    }

    .filter-field select {
      width: 100%;
      border: 1px solid var(--input-border);
      border-radius: 8px;
      padding: 9px 10px;
      font-size: 14px;
      outline: none;
      background: #fff;
    }

    .filter-field select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(45, 108, 223, 0.15);
    }

    .reset-filter-btn {
      background: #6c757d;
      color: #fff;
    }


    .legend-item {
      padding: 10px;
      border-radius: 8px;
      text-align: center;
      border: 1px solid #ddd;
      color: #222;
    }

    .legend-safe {
      background: #e9f8ee;
    }

    .legend-warning {
      background: #fff7d6;
    }

    .legend-overdue {
      background: #ffd6d6;
    }

    .task-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .task {
      position: relative;
      border-radius: 12px;
      padding: 14px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      border: 2px solid transparent;
      cursor: pointer;
    }

    .task:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    }

    .priority-corner {
      position: absolute;
      top: 0;
      right: 0;
      width: 0;
      height: 0;
      border-top: 28px solid #6c757d;
      border-left: 28px solid transparent;
      border-top-right-radius: 9px;
    }

    .priority-normal {
      border-top-color: #28a745;
    }

    .priority-important {
      border-top-color: #ffc107;
    }

    .priority-high {
      border-top-color: #dc3545;
    }

    .priority-legend {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 20px;
      font-size: 13px;
    }

    .priority-legend-item {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 10px;
      border: 1px solid #ddd;
      border-radius: 8px;
      background: var(--panel-bg);
    }

    .priority-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      display: inline-block;
    }

    .priority-dot.normal {
      background: #28a745;
    }

    .priority-dot.important {
      background: #ffc107;
    }

    .priority-dot.high {
      background: #dc3545;
    }

    .task.safe {
      background: #e9f8ee;
      border-color: #95d5a6;
    }

    .task.warning {
      background: #fff7d6;
      border-color: #f0d36b;
    }

    .task.overdue {
      background: #ffd6d6;
      border-color: #e05252;
    }

    .task.completed {
      background: #eef1f5;
      border-color: #c6ccd6;
    }

    .task-info {
      flex: 1;
    }

    .task-title {
      font-size: 16px;
      color: var(--text-main);
      margin-bottom: 5px;
      word-break: break-word;
    }

    .task-date,
    .task-deadline,
    .task-status,
    .task-description,
    .task-priority {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 3px;
    }

    .task-status strong,
    .task-priority strong {
      color: var(--text-main);
    }

    .task-description-preview {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 3px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .open-hint {
      font-size: 11px;
      color: var(--text-light);
      margin-top: 5px;
    }

    .task-actions {
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: stretch;
      justify-content: center;
      min-width: 115px;
    }

    .task-actions button {
      width: 100%;
      white-space: nowrap;
    }

    .complete-btn {
      background: #28a745;
      color: #fff;
    }

    .edit-btn {
      background: #ffc107;
      color: var(--text-main);
    }

    .delete-btn {
      background: #dc3545;
      color: #fff;
    }

    .restore-btn {
      background: #17a2b8;
      color: #fff;
    }

    .empty {
      text-align: center;
      color: #777;
      padding: 25px 0;
    }

    .clear-history {
      margin-top: 20px;
      width: 100%;
      background: #dc3545;
      color: #fff;
      display: none;
    }

    .clear-history.visible {
      display: block;
    }

    .toast-container {
      position: fixed;
      right: 20px;
      bottom: 20px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      z-index: 1000;
    }

    .toast {
      min-width: 260px;
      max-width: 340px;
      background: #222;
      color: #fff;
      padding: 14px 16px;
      border-radius: 10px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
      font-size: 14px;
      animation: slideIn 0.3s ease;
    }

    .toast-title {
      font-weight: bold;
      margin-bottom: 4px;
    }

    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.45);
      display: none;
      justify-content: center;
      align-items: center;
      padding: 15px;
      z-index: 900;
    }

    .modal-overlay.visible {
      display: flex;
    }

    .modal {
      width: 100%;
      max-width: 460px;
      background: var(--app-bg);
      border-radius: 16px;
      padding: 22px;
      box-shadow: 0 20px 50px var(--modal-shadow);
      animation: modalShow 0.25s ease;
    }

    .modal h2 {
      font-size: 22px;
      color: var(--text-main);
      margin-bottom: 6px;
    }

    .modal-subtitle {
      font-size: 13px;
      color: var(--text-light);
      margin-bottom: 18px;
    }

    .modal-form {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .modal-field {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .modal-field label {
      font-size: 13px;
      font-weight: bold;
      color: var(--text-main);
    }

    .modal-field input,
    .modal-field select,
    .modal-field textarea {
      width: 100%;
      border: 1px solid var(--input-border);
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 14px;
      outline: none;
      resize: vertical;
    }

    .modal-field input:focus,
    .modal-field select:focus,
    .modal-field textarea:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(45, 108, 223, 0.15);
    }

    .priority-preview {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: var(--text-muted);
      background: var(--panel-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 8px 10px;
    }

    .modal-actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 6px;
    }

    .details-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
      font-size: 14px;
      color: var(--text-muted);
    }

    .details-item {
      background: var(--panel-bg);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      padding: 10px;
      word-break: break-word;
      white-space: pre-wrap;
    }

    .details-item strong {
      color: var(--text-main);
    }

    .details-description {
      max-height: 220px;
      overflow-y: auto;
    }

    @keyframes slideIn {
      from {
        transform: translateX(120%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }

    @keyframes modalShow {
      from {
        transform: translateY(20px) scale(0.96);
        opacity: 0;
      }
      to {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
    }

    body.theme-dark .task.safe {
      background: #123524;
      border-color: #22c55e;
    }

    body.theme-dark .task.warning {
      background: #3f3212;
      border-color: #eab308;
    }

    body.theme-dark .task.overdue {
      background: #451a1a;
      border-color: #ef4444;
    }

    body.theme-dark .task.completed {
      background: #374151;
      border-color: #6b7280;
    }

    body.theme-dark .legend-safe {
      background: #e9f8ee;
    }

    body.theme-dark .legend-warning {
      background: #fff7d6;
    }

    body.theme-dark .legend-overdue {
      background: #ffd6d6;
    }

    body.theme-dark .modal-field input,
    body.theme-dark .modal-field select,
    body.theme-dark .modal-field textarea,
    body.theme-dark .filter-field select {
      background: #111827;
      color: var(--text-main);
    }

    body.theme-gradient-berries .app,
    body.theme-gradient-sunset .app,
    body.theme-gradient-ocean .app,
    body.theme-gradient-forest .app {
      backdrop-filter: blur(10px);
    }

    @media (max-width: 750px) {
      .theme-panel {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
      color: var(--text-muted);
      font-size: 14px;
    }

    .theme-panel select {
      border: 1px solid var(--input-border);
      border-radius: 8px;
      padding: 9px 10px;
      font-size: 14px;
      outline: none;
      background: var(--app-bg);
      color: var(--text-main);
      cursor: pointer;
    }

    .theme-panel select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(45, 108, 223, 0.15);
    }

    .top-panel {
        flex-direction: column;
        align-items: stretch;
      }

      .legend,
      .priority-legend {
        grid-template-columns: 1fr;
      }

      .task {
        flex-direction: column;
        align-items: stretch;
      }

      .task-actions {
        width: 100%;
        min-width: 0;
        justify-content: flex-start;
      }

      .stats {
        flex-direction: column;
      }

      .filters {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="toast-container" id="toastContainer"></div>

  <div class="modal-overlay" id="taskModal">
    <div class="modal">
      <h2 id="modalTitle">Нове завдання</h2>
      <p class="modal-subtitle">Налаштуйте завдання перед додаванням у список</p>

      <form class="modal-form" id="taskForm">
        <div class="modal-field">
          <label for="taskInput">Назва завдання</label>
          <input type="text" id="taskInput" placeholder="Наприклад: зробити лабораторну" />
        </div>

        <div class="modal-field">
          <label for="deadlineInput">Введіть час дедлайну</label>
          <input type="datetime-local" id="deadlineInput" />
        </div>

        <div class="modal-field">
          <label for="priorityInput">Важливість</label>
          <select id="priorityInput">
            <option value="Звичайна">Звичайна</option>
            <option value="Важлива">Важлива</option>
            <option value="Дуже важлива">Дуже важлива</option>
          </select>
          <div class="priority-preview" id="priorityPreview">
            <span class="priority-dot normal" id="priorityPreviewDot"></span>
            <span id="priorityPreviewText">Зелений — звичайна важливість</span>
          </div>
        </div>

        <div class="modal-field">
          <label for="categoryInput">Категорія завдання</label>
          <select id="categoryInput">
            <option value="Побут">Побут</option>
            <option value="Навчання">Навчання</option>
            <option value="Робота">Робота</option>
          </select>
        </div>

        <div class="modal-field">
          <label for="descriptionInput">Опис або примітка</label>
          <textarea id="descriptionInput" rows="3" placeholder="Можна залишити порожнім"></textarea>
        </div>

        <div class="modal-actions">
          <button type="button" class="cancel-modal-btn" id="cancelEditBtn">Скасувати</button>
          <button type="submit" class="save-task-btn" id="submitBtn">Додати</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="filterModal">
    <div class="modal">
      <h2>Фільтр завдань</h2>
      <p class="modal-subtitle">Оберіть, які завдання потрібно показати</p>

      <div class="filters">
        <div class="filter-field">
          <label for="priorityFilter">Фільтр за важливістю</label>
          <select id="priorityFilter">
            <option value="all">Усі завдання</option>
            <option value="Дуже важлива">Дуже важлива</option>
            <option value="Важлива">Важлива</option>
            <option value="Звичайна">Звичайна</option>
          </select>
        </div>

        <div class="filter-field">
          <label for="deadlineFilter">Фільтр за терміном</label>
          <select id="deadlineFilter">
            <option value="all">Усі терміни</option>
            <option value="overdue">Прострочені</option>
            <option value="one-day">1 день або менше</option>
            <option value="one-week">Тиждень або менше</option>
            <option value="two-weeks">Менше 2 тижнів</option>
            <option value="more-than-two-weeks">Більше 2 тижнів</option>
